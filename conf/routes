# --- Shipment Module ---

# Create a new shipment
POST    /shipments                          api.controllers.ShipmentController.createShipment

# Get all shipments
GET     /shipments                          api.controllers.ShipmentController.getAllShipments(page: Int ?= 1, pageSize: Int ?= 10)

# Get shipments by status (Uses the PathBindable)
GET     /shipments/status/:shipmentStatus   api.controllers.ShipmentController.getShipmentByStatus(shipmentStatus: domain.models.ShipmentStatus)

# Get shipment by Tracking Number
GET     /shipments/tracking/:trackingNumber api.controllers.ShipmentController.getShipmentByTrackingNumber(trackingNumber: String)

# Get shipment by UUID
GET     /shipments/:shipmentId              api.controllers.ShipmentController.getShipmentById(shipmentId: java.util.UUID)

# Update full shipment details
PUT     /shipments/:shipmentId              api.controllers.ShipmentController.updateShipment(shipmentId: java.util.UUID)

# Update only the status
PATCH   /shipments/tracking/:trackingNumber/status    api.controllers.ShipmentController.updateShipmentStatus(trackingNumber: String)

# Delete a shipment
DELETE  /shipments/:shipmentId              api.controllers.ShipmentController.deleteShipment(shipmentId: java.util.UUID)


# --- User Management Module ---

# Create a new user
POST    /users                          api.controllers.UserController.createUser

# Get all users
GET     /users                          api.controllers.UserController.findAllUsers(offset: Int ?= 1, limit: Int ?= 10)

# Get users by role (Uses the PathBindable)
GET     /users/role/:userRole   api.controllers.UserController.findUserByRole(userRole: domain.models.UserRole)

# Get user by UUID
GET     /users/:userId              api.controllers.UserController.findUserById(userId: java.util.UUID)

# Get user by email
GET     /users/:email            api.controllers.UserController.findUserByEmail(email: String)

# Update  user details
PUT     /users/:userId              api.controllers.UserController.updateUserDetails(userId: java.util.UUID)


# Delete a user
DELETE  /users/:userId              api.controllers.UserController.deleteUser(userId: java.util.UUID)